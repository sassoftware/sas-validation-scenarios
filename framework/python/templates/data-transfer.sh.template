echo "Setting 777 permissions for ${destination}"
ssh -o IdentitiesOnly=yes -o StrictHostKeyChecking=no -i ${pem_file} ${user}@${server} "chmod 777 ${destination}"
if [ $$? -ne 0 ]; then
        echo "ERROR: Error setting permissions: "
        echo " ssh -i ${pem_file} ${user}@${server} \"chmod 777 ${destination}\" "
        exit 1
fi

echo "File ${source} copied successfully."
