workload-definitions:
  workload-definition-specs:
    - name: ${name}
      description: ${description}
      custom-resource-spec:
        namespace: ${namespace}
        config-map-name: ${config_map_name}
        k8s-operator: ${k8s_operator}
        ${workloads}
        custom-modules:
          - name: ${custom_module_name}
            path: ${custom_module_path}
            task: ${custom_module_task}
